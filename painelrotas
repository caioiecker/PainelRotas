<style>
  :root{
    --bg: #EAF2FB;
    --panel: #FFFFFF;
    --panel-2: #E3EFFB;
    --line: #C9DEF2;
    --text: #16273B;
    --muted: #5D7C97;
    --accent: #3B93E0;
    --good: #1FA971;
    --warn: #E39A1F;
    --bad: #E2554F;
    --mono: 'JetBrains Mono', monospace;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;}
  ::selection{background:var(--accent);color:#ffffff;}

  .wrap{max-width:1900px;margin:0 auto;padding:24px 24px 50px;}

  /* HEADER */
  header{display:flex;align-items:flex-start;justify-content:space-between;gap:20px;margin-bottom:26px;flex-wrap:wrap;}
  .brand-eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin:0 0 6px;}
  h1{font-family:'Space Grotesk',sans-serif;font-size:28px;font-weight:700;margin:0 0 4px;letter-spacing:-.01em;}
  .sub{color:var(--muted);font-size:13.5px;margin:0;}
  .sub span{color:var(--text);font-family:var(--mono);}

  .import-zone{display:flex;flex-direction:column;align-items:flex-end;gap:6px;}
  .btn-import{
    display:flex;align-items:center;gap:8px;
    background:var(--accent);color:#ffffff;border:none;
    font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:13.5px;
    padding:11px 16px;border-radius:8px;cursor:pointer;
    transition:transform .12s ease, box-shadow .12s ease;
    box-shadow:0 0 0 0 rgba(59,147,224,.4);
  }
  .btn-import:hover{transform:translateY(-1px);box-shadow:0 6px 16px -4px rgba(59,147,224,.5);}
  .btn-import:active{transform:translateY(0);}
  .btn-import svg{width:15px;height:15px;flex:none;}
  #file-input{display:none;}

  .btn-undo{
    display:flex;align-items:center;gap:7px;
    background:transparent;color:var(--accent);border:1px solid var(--line);
    font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:12.5px;
    padding:8px 14px;border-radius:8px;cursor:pointer;
    transition:background .12s ease, border-color .12s ease;
  }
  .btn-undo svg{width:13px;height:13px;flex:none;}
  .btn-undo:hover:not(:disabled){background:var(--panel-2);border-color:var(--accent);}
  .btn-undo:disabled{color:var(--muted);border-color:var(--line);cursor:not-allowed;opacity:.55;}

  .import-hint{font-family:var(--mono);font-size:10.5px;color:var(--muted);}
  .import-status{font-family:var(--mono);font-size:11px;padding:3px 8px;border-radius:5px;display:none;}
  .import-status.ok{display:inline-block;background:rgba(52,211,153,.12);color:var(--good);}
  .import-status.err{display:inline-block;background:rgba(240,101,75,.12);color:var(--bad);}

  /* KPI CARDS */
  .kpis{display:grid;grid-template-columns:repeat(7,1fr);gap:12px;margin-bottom:22px;}
  .kpi{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:16px;position:relative;overflow:hidden;}
  .kpi::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--kpi-color, var(--accent));}
  .kpi-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin:0 0 8px;font-weight:700;}
  .kpi-value{font-family:var(--mono);font-size:26px;font-weight:600;margin:0;line-height:1;}
  .kpi-value small{font-size:13px;color:var(--muted);font-weight:400;}
  .kpi-note{font-family:var(--mono);font-size:11px;color:var(--muted);margin:6px 0 0;}

  /* PANEL */
  .panel{background:var(--panel);border:1px solid var(--line);border-radius:12px;overflow:hidden;margin-bottom:20px;}
  .panel-head{display:flex;align-items:flex-start;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--line);gap:12px;flex-wrap:wrap;}
  .panel-head h2{font-family:'Space Grotesk',sans-serif;font-size:15px;margin:0;font-weight:600;}
  .panel-sub{font-size:11.5px;color:var(--muted);margin:3px 0 0;}
  .panel-head-text{display:flex;flex-direction:column;}
  .panel-head .count{font-family:var(--mono);font-size:11.5px;color:var(--muted);white-space:nowrap;}

  /* FLEET PANEL */
  .fleet-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:10px;padding:16px 18px;}
  .fleet-item{
    display:flex;align-items:center;justify-content:space-between;gap:8px;
    background:var(--panel-2);border:1px solid var(--line);border-radius:8px;padding:10px 12px;
  }
  .fleet-item.has-target{justify-content:space-between;}
  .fleet-target-count{font-family:var(--mono);font-size:16px;font-weight:600;}
  .fleet-target-count b{color:var(--text);}
  .fleet-num.bad{color:var(--bad);}
  .fleet-num.warn{color:var(--warn);}
  .fleet-num.good{color:var(--good);}
  .fleet-num.over{color:var(--accent);}
  .fleet-name{font-size:12.5px;color:var(--text);}
  .fleet-count{font-family:var(--mono);font-size:16px;font-weight:600;color:var(--accent);flex:none;}

  /* LEGEND */
  .legend{display:flex;align-items:center;gap:14px;padding:12px 18px;border-bottom:1px solid var(--line);flex-wrap:wrap;background:var(--panel-2);}
  .legend-item{display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--muted);}
  .legend-dot{width:8px;height:8px;border-radius:50%;flex:none;}
  .legend-item.ok .legend-dot{background:var(--good);}
  .legend-item.fail .legend-dot{background:var(--bad);}
  .legend-item.pend .legend-dot{background:var(--warn);}
  .legend-note{font-size:11px;color:var(--muted);margin-left:auto;}

  /* FILTER BAR */
  .filter-bar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
  .filter-input-wrap{position:relative;}
  #driver-search{
    background:var(--panel-2);border:1px solid var(--line);color:var(--text);
    font-family:'Inter',sans-serif;font-size:12.8px;padding:8px 12px 8px 30px;border-radius:7px;
    width:220px;outline:none;transition:border-color .12s ease;
  }
  #driver-search:focus{border-color:var(--accent);}
  .filter-input-wrap svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);width:14px;height:14px;color:var(--muted);pointer-events:none;}
  #vehicle-filter{
    background:var(--panel-2);border:1px solid var(--line);color:var(--text);
    font-family:'Inter',sans-serif;font-size:12.5px;padding:8px 10px;border-radius:7px;outline:none;
  }
  .btn-clear{
    background:transparent;border:1px solid var(--line);color:var(--muted);
    font-family:var(--mono);font-size:11px;padding:7px 10px;border-radius:7px;cursor:pointer;
  }
  .btn-clear:hover{color:var(--text);border-color:var(--muted);}

  /* TABLE */
  table{width:100%;table-layout:fixed;border-collapse:collapse;font-size:11.8px;}
  thead th{
    text-align:left;font-family:var(--mono);font-size:9.5px;text-transform:uppercase;letter-spacing:.03em;
    color:var(--muted);padding:9px 8px;border-bottom:1px solid var(--line);white-space:normal;font-weight:700;
    overflow-wrap:break-word;
  }
  tbody td{padding:9px 8px;border-bottom:1px solid var(--line);vertical-align:middle;white-space:normal;overflow-wrap:break-word;word-break:break-word;}
  tbody tr:last-child td{border-bottom:none;}
  tbody tr:nth-child(even){background:rgba(59,147,224,.035);}
  tbody tr:hover{background:var(--panel-2);}
  .route-id{font-family:var(--mono);color:var(--text);font-weight:500;font-size:11.5px;}
  .route-code{display:block;font-family:var(--mono);font-size:9.5px;color:var(--muted);}
  .driver{color:var(--text);}
  .badge{
    display:inline-block;padding:3px 7px;border-radius:5px;font-size:10px;font-family:var(--mono);
    background:var(--panel-2);color:var(--muted);border:1px solid var(--line);white-space:normal;line-height:1.3;
  }
  .num-good{color:var(--good);font-family:var(--mono);}
  .num-bad{color:var(--bad);font-family:var(--mono);}
  .num-warn{color:var(--warn);font-family:var(--mono);}
  .num{font-family:var(--mono);}
  .ozh-orh-labels{display:flex;justify-content:space-between;font-size:9px;letter-spacing:.04em;color:var(--muted);margin-bottom:2px;}
  .ozh-orh-value{font-size:11.5px;white-space:nowrap;}

  /* manifest strip = signature element */
  .strip{width:100%;max-width:80px;height:8px;border-radius:4px;overflow:hidden;display:flex;background:var(--line);}
  .strip div{height:100%;}
  .strip .s-ok{background:var(--good);}
  .strip .s-fail{background:var(--bad);}
  .strip .s-pend{background:var(--warn);}
  .strip-pct{font-family:var(--mono);font-size:11px;color:var(--muted);margin-left:8px;}
  .strip-cell{display:flex;align-items:center;}

  colgroup col.c-rota{width:11%;}
  colgroup col.c-motorista{width:13%;}
  colgroup col.c-veiculo{width:11%;}
  colgroup col.c-base{width:6%;}
  colgroup col.c-pacotes{width:6%;}
  colgroup col.c-sucesso{width:6%;}
  colgroup col.c-falha{width:6%;}
  colgroup col.c-pendente{width:6.5%;}
  colgroup col.c-progresso{width:9%;}
  colgroup col.c-reclamacoes{width:8%;}
  colgroup col.c-contato{width:8.5%;}
  colgroup col.c-janela{width:8%;}

  /* LEADERBOARD: PROMOTORES & OFENSORES */
  .leader-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;padding:16px 18px;}
  @media (max-width:800px){ .leader-grid{grid-template-columns:1fr;} }
  .leader-col h3{
    font-family:'Space Grotesk',sans-serif;font-size:13px;margin:0 0 10px;font-weight:600;
    display:flex;align-items:center;gap:7px;
  }
  .leader-col.promo h3{color:var(--good);}
  .leader-col.offend h3{color:var(--bad);}
  .leader-col h3 .dot{width:8px;height:8px;border-radius:50%;flex:none;}
  .leader-col.promo h3 .dot{background:var(--good);}
  .leader-col.offend h3 .dot{background:var(--bad);}
  .leader-list{display:flex;flex-direction:column;gap:8px;}
  .leader-item{
    display:flex;align-items:center;gap:10px;
    background:var(--panel-2);border:1px solid var(--line);border-radius:8px;padding:10px 12px;
  }
  .leader-col.offend .leader-item{border-left:3px solid var(--bad);}
  .leader-col.promo .leader-item{border-left:3px solid var(--good);}
  .leader-rank{font-size:15px;width:20px;flex:none;text-align:center;}
  .leader-name{flex:1;font-size:12.3px;color:var(--text);text-transform:capitalize;}
  .leader-metric{font-family:var(--mono);font-size:11px;white-space:nowrap;font-weight:600;}

  .empty{padding:40px;text-align:center;color:var(--muted);font-size:13px;}

  footer{color:var(--muted);font-size:11px;font-family:var(--mono);text-align:center;margin-top:8px;}

  @media (max-width:920px){
    .kpis{grid-template-columns:repeat(3,1fr);}
    header{flex-direction:column;}
    .import-zone{align-items:flex-start;}
  }
  @media (max-width:560px){
    .kpis{grid-template-columns:repeat(2,1fr);}
  }
  @media (min-width:921px) and (max-width:1180px){
    .kpis{grid-template-columns:repeat(4,1fr);}
  }
</style>
</head>
