<script>
(function(){
  const $ = (s)=>document.querySelector(s);
  let allRoutes = [];

  function parseRow(cols){
    const raw = (cols[0]||'').trim();
    const parts = raw.split('·').map(s=>s.trim());
    const routeLabel = parts[0] || raw;
    const routeCode = parts[1] || '';
    const plate = (cols[1]||'').trim();
    const vehicle = (cols[2]||'').trim();
    const branch = (cols[3]||'').trim();
    const driver = (cols[4]||'').trim();

    const contactMatch = (cols[5]||'').match(/([\d.,]+)\s*%/);
    const contactRate = contactMatch ? contactMatch[1] : '0';

    const complaintsMatch = (cols[6]||'').match(/(\d+)/);
    const complaints = complaintsMatch ? parseInt(complaintsMatch[1],10) : 0;

    const statusNums = (cols[8]||'').match(/\d+/g) || ['0','0','0'];
    const pending = parseInt(statusNums[0]||0,10);
    const failed = parseInt(statusNums[1]||0,10);
    const success = parseInt(statusNums[2]||0,10);
    const total = pending+failed+success;

    const extractTime = (s)=>{
      if(!s) return '';
      const m = String(s).match(/(\d{1,2}):(\d{2})(?::\d{2})?/);
      return m ? m[1].padStart(2,'0')+':'+m[2] : String(s).trim();
    };
    const start = extractTime((cols[14]||'').trim());
    const end = extractTime((cols[15]||'').trim());

    return {routeLabel, routeCode, plate, vehicle, branch, driver, contactRate, complaints, pending, failed, success, total, start, end};
  }

  function parseCsvText(text){
    return text.split(/\r?\n/).filter(l=>l.trim().length>0).map(line=>line.split(';'));
  }

  function fmtNum(n){ return new Intl.NumberFormat('pt-BR').format(n); }

  function renderSummary(routes){
    const totalRoutes = routes.length;
    const totalSuccess = routes.reduce((a,r)=>a+r.success,0);
    const totalFailed = routes.reduce((a,r)=>a+r.failed,0);
    const totalPending = routes.reduce((a,r)=>a+r.pending,0);
    const totalComplaints = routes.reduce((a,r)=>a+r.complaints,0);
    const totalUnits = totalSuccess+totalFailed+totalPending;
    const successRate = totalUnits ? (totalSuccess/totalUnits*100) : 0;

    const branchSet = [...new Set(routes.map(r=>r.branch.split('·')[0].trim()).filter(Boolean))];
    $('#branch-name').textContent = branchSet.join(', ') || '—';

    const kpis = [
      {label:'Rotas ativas', value: fmtNum(totalRoutes), color:'var(--accent)'},
      {label:'Pacotes totais', value: fmtNum(totalUnits), color:'var(--accent)'},
      {label:'Entregas com sucesso', value: fmtNum(totalSuccess), color:'var(--good)'},
      {label:'Entregas com falha', value: fmtNum(totalFailed), color:'var(--bad)'},
      {label:'Entregas pendentes', value: fmtNum(totalPending), color:'var(--warn)'},
      {label:'Reclamações totais', value: fmtNum(totalComplaints), color:'var(--bad)'},
      {label:'Taxa de sucesso', value: successRate.toFixed(1)+'<small>%</small>', color:'var(--good)', note:'META: 99,0%'},
    ];
    $('#kpis').innerHTML = kpis.map(k=>`
      <div class="kpi" style="--kpi-color:${k.color}">
        <p class="kpi-label">${k.label}</p>
        <p class="kpi-value">${k.value}</p>
        ${k.note ? `<p class="kpi-note">${k.note}</p>` : ''}
      </div>
    `).join('');
  }

  // metas de utilização de frota (nº de veículos esperados por tipo)
  const FLEET_TARGETS = {
    'utilitarios sdd': 13,
    'vuc sdd': 5
  };
  function normalizeVehicleName(name){
    return (name||'')
      .toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g,''); // remove acentos
  }

  function renderFleet(routes){
    const counts = new Map();
    routes.forEach(r=>{
      const key = r.vehicle || 'Não informado';
      counts.set(key, (counts.get(key)||0)+1);
    });
    const entries = [...counts.entries()].sort((a,b)=> b[1]-a[1] || a[0].localeCompare(b[0]));
    $('#fleet-count').textContent = entries.length + ' tipo' + (entries.length===1?'':'s') + ' de veículo · ' + routes.length + ' veículos no total';
    $('#fleet-grid').innerHTML = entries.map(([name,count])=>{
      const target = FLEET_TARGETS[normalizeVehicleName(name)];
      if(!target){
        return `
      <div class="fleet-item">
        <span class="fleet-name">${name}</span>
        <span class="fleet-count">${count}</span>
      </div>`;
      }
      const pct = Math.round((count/target)*100);
      let barClass = 'good';
      if(count > target) barClass = 'over';
      else if(count === target) barClass = 'good';
      else if(pct >= 70) barClass = 'warn';
      else barClass = 'bad';
      return `
      <div class="fleet-item has-target">
        <span class="fleet-name">${name}</span>
        <span class="fleet-target-count"><b class="fleet-num ${barClass}">${count}</b>/<b>${target}</b></span>
      </div>`;
    }).join('') || '<div class="empty">Sem dados de frota.</div>';

    // keep the vehicle filter dropdown in sync
    const select = $('#vehicle-filter');
    const current = select.value;
    select.innerHTML = '<option value="">Todos os veículos</option>' +
      entries.map(([name,count])=>`<option value="${name}">${name} (${count})</option>`).join('');
    if(entries.some(([name])=>name===current)) select.value = current;
  }

  function populateDriverList(routes){
    const names = [...new Set(routes.map(r=>r.driver).filter(Boolean))].sort((a,b)=>a.localeCompare(b));
    $('#driver-list').innerHTML = names.map(n=>`<option value="${n}"></option>`).join('');
  }

  function renderTable(routes){
    $('#route-count').textContent = routes.length + ' rota' + (routes.length===1?'':'s');
    const tbody = $('#route-tbody');
    if(!routes.length){
      tbody.innerHTML = `<tr><td colspan="12" class="empty">Nenhuma rota encontrada para esse filtro.</td></tr>`;
      return;
    }
    tbody.innerHTML = routes.map(r=>{
      const pctOk = r.total ? (r.success/r.total*100) : 0;
      const pctFail = r.total ? (r.failed/r.total*100) : 0;
      const pctPend = r.total ? (r.pending/r.total*100) : 0;
      return `
      <tr>
        <td>
          <span class="route-id">${r.routeLabel}</span>
          <span class="route-code">${r.routeCode}${r.plate ? ' · '+r.plate : ''}</span>
        </td>
        <td class="driver">${r.driver}</td>
        <td><span class="badge">${r.vehicle||'—'}</span></td>
        <td><span class="badge">${r.branch||'—'}</span></td>
        <td class="num">${fmtNum(r.total)}</td>
        <td class="num-good">${fmtNum(r.success)}</td>
        <td>
          <span class="num-bad">${fmtNum(r.failed)}</span>
        </td>
        <td class="num-warn">${fmtNum(r.pending)}</td>
        <td>
          <div class="strip" title="${r.success} sucesso · ${r.failed} falha · ${r.pending} pendente">
            <div class="s-ok" style="width:${pctOk}%"></div>
            <div class="s-fail" style="width:${pctFail}%"></div>
            <div class="s-pend" style="width:${pctPend}%"></div>
          </div>
        </td>
        <td class="${r.complaints>0?'num-warn':'num'}">${fmtNum(r.complaints)}</td>
        <td class="num">${r.contactRate}%</td>
        <td class="num">${r.start} - ${r.end}</td>
      </tr>`;
    }).join('');
  }

  function renderLeaders(routes){
    // agrupa por motorista, somando todas as rotas de cada um
    const map = new Map();
    routes.forEach(r=>{
      if(!r.driver) return;
      if(!map.has(r.driver)){
        map.set(r.driver, {driver:r.driver, total:0, success:0, failed:0, pending:0, routes:0});
      }
      const d = map.get(r.driver);
      d.total += r.total;
      d.success += r.success;
      d.failed += r.failed;
      d.pending += r.pending;
      d.routes += 1;
    });
    const drivers = [...map.values()].map(d=>({...d, rate: d.total ? (d.success/d.total*100) : 0}));

    // promotores: 100% de sucesso (sem nenhuma falha/pendência), desempate por volume de pacotes
    const promoters = drivers
      .filter(d=>d.total>0 && d.failed===0 && d.pending===0)
      .sort((a,b)=> b.total-a.total)
      .slice(0,3);

    // ofensores: maior número absoluto de falhas, desempate por menor taxa de sucesso
    const offenders = drivers
      .filter(d=>d.failed>0)
      .sort((a,b)=> b.failed-a.failed || a.rate-b.rate)
      .slice(0,3);

    const medal = ['🥇','🥈','🥉'];

    $('#leader-count').textContent = drivers.length + ' motorista' + (drivers.length===1?'':'es') + ' no total';

    $('#promoters-list').innerHTML = promoters.length ? promoters.map((d,i)=>`
      <div class="leader-item">
        <span class="leader-rank">${medal[i]}</span>
        <span class="leader-name">${d.driver}</span>
        <span class="leader-metric num-good">${fmtNum(d.total)} pacotes · 100%</span>
      </div>
    `).join('') : '<div class="empty">Nenhum motorista com 100% das entregas nesse período.</div>';

    $('#offenders-list').innerHTML = offenders.length ? offenders.map((d,i)=>`
      <div class="leader-item">
        <span class="leader-rank">${medal[i]}</span>
        <span class="leader-name">${d.driver}</span>
        <span class="leader-metric num-bad">${fmtNum(d.failed)} falha${d.failed===1?'':'s'} · ${d.rate.toFixed(1)}% sucesso</span>
      </div>
    `).join('') : '<div class="empty">Nenhuma falha registrada.</div>';
  }

  // wrapper de armazenamento: tenta window.storage (funciona dentro do Claude),
  // e cai para localStorage do navegador quando essa API não existe
  // (ex.: arquivo .html aberto direto do computador)
  async function storageGet(key){
    try{
      if(window.storage && typeof window.storage.get === 'function'){
        return await window.storage.get(key, false);
      }
    }catch(e){ /* segue para o fallback */ }
    try{
      const raw = localStorage.getItem('painel-rotas:'+key);
      return raw ? {value: raw} : null;
    }catch(e){
      return null;
    }
  }

  async function storageSet(key, value){
    try{
      if(window.storage && typeof window.storage.set === 'function'){
        const r = await window.storage.set(key, value, false);
        if(r) return r;
      }
    }catch(e){ /* segue para o fallback */ }
    try{
      localStorage.setItem('painel-rotas:'+key, value);
      return {value};
    }catch(e){
      return null;
    }
  }

  // reconstrói uma linha no mesmo formato do seed-csv a partir de uma rota já processada
  function routeToCsvRow(r){
    const col0 = r.routeCode ? `${r.routeLabel} · ${r.routeCode}` : r.routeLabel;
    const fields = [
      col0,
      r.plate || '',
      r.vehicle || '',
      r.branch || '',
      r.driver || '',
      `Contact rate: ${r.contactRate}%`,
      `Totales reclamações: ${r.complaints}`,
      String(r.total || ''),
      `${r.pending} pendentes, ${r.failed} com falhas, ${r.success} bem-sucedidos`,
      '', '', '', '', '',
      r.start ? `${r.start} h` : '',
      r.end ? `${r.end} h` : ''
    ];
    return fields.join(';');
  }

  // gera uma cópia do próprio arquivo .html, com os dados atualmente carregados
  // embutidos como dado padrão — assim os dados ficam salvos no arquivo em si,
  // sem depender de nenhuma API de armazenamento do navegador
  function downloadUpdatedHtml(){
    try{
      const newCsv = allRoutes.map(routeToCsvRow).join('\n');
      let html = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
      html = html.replace(
        /(<script type="text\/plain" id="seed-csv">)[\s\S]*?(<\/script>)/,
        (m, open, close) => open + newCsv + close
      );
      const blob = new Blob([html], {type:'text/html;charset=utf-8'});
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'Painel_de_Rotas_SMG2.html';
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      status.className = 'import-status ok';
      status.textContent = '✓ HTML atualizado baixado — use esse arquivo na próxima vez';
    }catch(err){
      status.className = 'import-status err';
      status.textContent = 'Erro ao gerar o HTML atualizado';
      console.error(err);
    }
  }

  function applyFilters(){
    const term = $('#driver-search').value.trim().toLowerCase();
    const vehicle = $('#vehicle-filter').value;
    const filtered = allRoutes.filter(r=>
      (!term || r.driver.toLowerCase().includes(term)) &&
      (!vehicle || r.vehicle === vehicle)
    );
    renderTable(filtered);
  }

  function applyRoutes(routes){
    allRoutes = routes;
    $('#driver-search').value = '';
    renderSummary(allRoutes);
    renderFleet(allRoutes);
    renderLeaders(allRoutes);
    populateDriverList(allRoutes);
    applyFilters();
  }

  function loadFromRows(rows){
    const parsed = rows.map(parseRow).filter(r => r.driver && (r.total>0 || r.complaints>0 || r.routeLabel));
    applyRoutes(parsed);
  }

  $('#driver-search').addEventListener('input', applyFilters);
  $('#vehicle-filter').addEventListener('change', applyFilters);
  $('#btn-clear-filters').addEventListener('click', ()=>{
    $('#driver-search').value = '';
    $('#vehicle-filter').value = '';
    applyFilters();
  });

  // import handling
  const fileInput = $('#file-input');
  const status = $('#import-status');
  const undoBtn = $('#btn-undo-import');
  const saveBtn = $('#btn-save-import');
  let previousRoutes = null;
  let lastImportedFileName = '';

  // initial load: try previously saved import first, fall back to embedded seed data
  (async function initialLoad(){
    try{
      const saved = await storageGet('last-import');
      if(saved && saved.value){
        const data = JSON.parse(saved.value);
        if(Array.isArray(data.routes) && data.routes.length){
          allRoutes = [];
          applyRoutes(data.routes);
          saveBtn.disabled = false;
          status.className='import-status ok';
          status.textContent = '✓ última importação salva carregada' + (data.fileName ? ' ('+data.fileName+')' : '');
          return;
        }
      }
    }catch(err){
      // no saved import yet, or storage unavailable — fall back to seed
    }
    const seedText = document.getElementById('seed-csv').textContent;
    loadFromRows(parseCsvText(seedText));
  })();

  $('#btn-import').addEventListener('click', ()=>fileInput.click());

  fileInput.addEventListener('change', (e)=>{
    const file = e.target.files[0];
    if(!file) return;
    status.className='import-status';
    status.textContent='';

    const reader = new FileReader();
    const isCsv = /\.csv$/i.test(file.name);

    reader.onload = function(evt){
      try{
        let rows;
        if(isCsv){
          rows = parseCsvText(evt.target.result);
        } else {
          const wb = XLSX.read(evt.target.result, {type:'array'});
          const sheet = wb.Sheets[wb.SheetNames[0]];
          rows = XLSX.utils.sheet_to_json(sheet, {header:1, raw:false, defval:''})
            .map(r=>r.map(c=>String(c)))
            .filter(r=>r.some(c=>c.trim()!==''));
        }
        previousRoutes = allRoutes.slice();
        undoBtn.disabled = false;
        saveBtn.disabled = false;
        lastImportedFileName = file.name;
        loadFromRows(rows);
        status.className='import-status ok';
        status.textContent = '✓ '+file.name+' importado';
      }catch(err){
        status.className='import-status err';
        status.textContent = 'Erro ao ler o arquivo';
        console.error(err);
      }
    };

    if(isCsv){ reader.readAsText(file, 'UTF-8'); }
    else { reader.readAsArrayBuffer(file); }

    fileInput.value = '';
  });

  undoBtn.addEventListener('click', ()=>{
    if(!previousRoutes) return;
    applyRoutes(previousRoutes);
    previousRoutes = null;
    undoBtn.disabled = true;
    status.className='import-status ok';
    status.textContent = '✓ última importação desfeita';
  });

  saveBtn.addEventListener('click', async ()=>{
    try{
      const payload = JSON.stringify({ fileName: lastImportedFileName, routes: allRoutes });
      const result = await storageSet('last-import', payload);
      if(result){
        status.className='import-status ok';
        status.textContent = '✓ importação salva para a próxima vez';
      } else {
        status.className='import-status err';
        status.textContent = 'Não foi possível salvar automaticamente — use "Baixar HTML atualizado"';
      }
    }catch(err){
      status.className='import-status err';
      status.textContent = 'Erro ao salvar — use "Baixar HTML atualizado"';
      console.error(err);
    }
  });

  $('#btn-download-html').addEventListener('click', downloadUpdatedHtml);
})();
</script>


